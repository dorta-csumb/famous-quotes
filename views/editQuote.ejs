<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Edit Quote</title>
</head>
<body>
    <%- include('partials/nav') %>
    <div class="container mt-4" style="max-width: 600px;">
        <h2 class="text-primary mb-4">Edit Quote</h2>
        <form action="/admin/quote/edit" method="POST" class="card p-4 shadow-sm">
            <input type="hidden" name="quoteId" value="<%= quote.quoteId %>">
            
            <div class="mb-3">
                <label>Quote text:</label>
                <textarea name="quote" class="form-control" rows="3" required><%= quote.quote %></textarea>
            </div>
            <div class="mb-3">
                <label>Author:</label>
                <select name="authorId" class="form-control" required>
                    <% for(let a of authors) { %>
                        <option value="<%= a.authorId %>" <%= quote.authorId === a.authorId ? 'selected' : '' %>>
                            <%= a.firstName %> <%= a.lastName %>
                        </option>
                    <% } %>
                </select>
            </div>
            <div class="mb-3">
                <label>Category:</label>
                <input type="text" name="category" list="categoryList" value="<%= quote.category %>" class="form-control" required>
                <datalist id="categoryList">
                    <% for(let c of categories) { %>
                        <option value="<%= c.category %>"></option>
                    <% } %>
                </datalist>
            </div>
            <div class="mb-3">
                <label>Likes:</label>
                <input type="number" name="likes" value="<%= quote.likes %>" class="form-control" required>
            </div>
            <button class="btn btn-primary fw-bold">Update Quote</button>
            <a href="/admin" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
    <%- include('partials/footer') %>
</body>
</html>