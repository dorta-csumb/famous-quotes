<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Likes Search Results</title>
</head>
<body>
    <!-- The following line include the navigation bar from the 'partials/nav.ejs' file, allowing for consistent navigation across the site and reducing code duplication. -->
    <%- include('partials/nav') %>
   
    <div class="container mt-4">
        <h1><%= searchType %></h1>
        <a href="/" class="btn btn-secondary mb-4">Back to Search</a>

        <% for (let i of rows) { %>
            <div class="card p-3 mb-3 quote-card shadow-sm">
                <h4>"<%= i.quote %>"</h4>
                
                <!-- NEW: Changed href to "#" and added class="authorNames" and authorId so JS picks it up -->
                <a href="#" class="authorNames author-name" authorId="<%= i.authorId %>">
                    - <%= i.firstName %> <%= i.lastName %>
                </a>
                <p class="text-success mt-2 mb-0"><strong>Likes: <%= i.likes %></strong></p>
            </div>
        <% } %>
    </div>
    <%- include('partials/footer') %>

    <!-- NEW: Added the modal HTML so it exists on the likes page -->
    <div>
        <dialog id="authorModal" class="p-4 border-0 shadow rounded" style="max-width: 500px;" > 
        <div id="authorInfo" class="text-center" >
            <h2 id="authorName" class="text-primary mb-3"></h2>
            <img id="authorPicture" class="img-fluid rounded mb-3" style="max-height: 250px; object-fit: contain;" alt="Author Picture">
            <p><strong>Profession:</strong> <span id="authorProfession"></span></p>
            <p><strong>Born:</strong> <span id="authorDob"></span> in <span id="authorCountry"></span></p>
            <p><strong>Died:</strong> <span id="authorDod"></span></p>
            <hr>
            <p id="authorBio" class="text-start"></p>
            <button id="closeModal" class="btn btn-secondary mt-3">Close</button>
        </div>
        </dialog>
    </div>
 
    <!-- NEW: Added the JS script so clicking the author actually opens the modal -->
    <script src="/js/quotes.js"></script>


<!-- the NEW additions ensure the modal functionality works on the likes page because the modal HTML and JS script are now included, allowing users to click on an author's name and view their profile in a modal window. -->

</body>
</html>