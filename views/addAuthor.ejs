<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Add Author</title>
</head>
<body>
    <%- include('partials/nav') %>
    <div class="container mt-4" style="max-width: 600px;">
        <h2 class="text-success mb-4">Add New Author</h2>
        <form action="/admin/author/add" method="POST" class="card p-4 shadow-sm">
            <div class="row">
                <div class="col-md-6 mb-3"><label>First Name:</label><input type="text" name="firstName" class="form-control" required></div>
                <div class="col-md-6 mb-3"><label>Last Name:</label><input type="text" name="lastName" class="form-control" required></div>
                <div class="col-md-6 mb-3"><label>Date of Birth:</label><input type="date" name="dob" class="form-control" required></div>
                <div class="col-md-6 mb-3"><label>Date of Death (Leave blank if alive):</label><input type="date" name="dod" class="form-control"></div>
                <div class="col-md-6 mb-3"><label>Sex (M/F):</label><input type="text" name="sex" class="form-control" maxlength="1" required></div>
                <div class="col-md-6 mb-3"><label>Profession:</label><input type="text" name="profession" class="form-control" required></div>
                <div class="col-md-12 mb-3"><label>Country:</label><input type="text" name="country" class="form-control" required></div>
                <div class="col-md-12 mb-3"><label>Portrait Image URL:</label><input type="url" name="portrait" class="form-control" required></div>
                <div class="col-md-12 mb-3"><label>Biography:</label><textarea name="biography" class="form-control" rows="4" required></textarea></div>
            </div>
            <button class="btn btn-success fw-bold mt-2">Submit New Author</button>
            <a href="/admin" class="btn btn-secondary mt-2">Cancel</a>
        </form>
    </div>
    <%- include('partials/footer') %>
</body>
</html>