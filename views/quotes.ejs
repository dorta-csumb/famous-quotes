<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Search Results</title>
</head>
<body>
    <!-- The following line includes the navigation bar from the 'partials/nav.ejs' file. This allows us to reuse the same navigation bar across multiple pages of our application, ensuring consistency and reducing code duplication. By using EJS's include syntax, we can easily maintain and update the navigation bar in one place, and those changes will be reflected on all pages that include it. -->
    <%- include('partials/nav') %>

    <div class="container mt-4">
        <h1><%= searchType %></h1>
        <a href="/" class="btn btn-secondary mb-4">Back to Search</a>

        <% for (let i of rows) { %>
            <div class="card p-3 mb-3 quote-card shadow-sm">
                
                <h4>"<%= i.quote %>"</h4>
                <!-- Author name is clickable and passes their ID to the authorInfo route -->
                <a href="#" class="authorNames" authorId="<%= i.authorId %>"> 
                    - <%= i.firstName %> <%= i.lastName %>
                </a>
            </div>
        <% } %>
    </div>
    <%- include('partials/footer') %>

    <div>
        <dialog id="authorModal" class="p-4 border-0 shadow rounded" style="max-width: 500px;" > 
        <div id="authorInfo" class="text-center" >
            <h2 id="authorName" class="text-primary mb-3"></h2>

            <img id="authorPicture" class="img-fluid rounded mb-3" style="max-height: 250px; object-fit: contain;" alt="Author Picture">

            <p><strong>Profession:</strong> <span id="authorProfession"></span></p>
            <p><strong>Born:</strong> <span id="authorDob"></span> in <span id="authorCountry"></span></p>
            <p><strong>Died:</strong> <span id="authorDod"></span></p>
            <hr>
            <p id="authorBio" class="text-start"></p>

            <button id="closeModal" class="btn btn-secondary mt-3">Close</button>

            
        </div>
        </dialog>

    </div>
 
    <script src="/js/quotes.js"></script>

</body>
</html>