<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Author Profile</title>
</head>
<body>
    <div class="container mt-4 text-center">
        <h1 class="text-primary"><%= author.firstName %> <%= author.lastName %></h1>
        <a href="/" class="btn btn-secondary mb-4">Back to Search</a>

        <div class="card mx-auto p-4 shadow" style="max-width: 600px;">
            <img src="<%= author.portrait %>" alt="Photo of <%= author.lastName %>" class="img-fluid rounded mb-3" style="max-height: 300px; object-fit: contain;">
            
            <p><strong>Profession:</strong> <%= author.profession %></p>
            <p><strong>Born:</strong> <%= author.dob %> in <%= author.country %></p>
            
            <% if (author.dod) { %>
                <p><strong>Died:</strong> <%= author.dod %></p>
            <% } else { %>
                <p><strong>Died:</strong> Present</p>
            <% } %>

            <hr>
            <p class="text-start"><%= author.biography %></p>
        </div>
    </div>
    <%- include('partials/footer') %>
</body>
</html>