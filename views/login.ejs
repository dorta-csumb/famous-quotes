<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title>Admin Login</title>
</head>
<body>
    <%- include('partials/nav') %>
    
    <div class="container mt-5">
        <div class="card shadow-sm mx-auto p-4" style="max-width: 400px;">
            <h2 class="mb-4 text-center text-primary">Admin Login</h2>
            
            <!-- Dr. Lara's error handling -->
            <% if (typeof loginError !== 'undefined') { %>
                <div class="alert alert-danger fw-bold text-center"><%= loginError %></div>
            <% } %>
            
            <form action="/login" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">Username:</label>
                    <input type="text" name="username" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Password:</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <button class="btn btn-primary w-100 fw-bold">Login</button>
            </form>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>